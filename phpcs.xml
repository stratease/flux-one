<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="Flux One" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/squizlabs/PHP_CodeSniffer/master/phpcs.xsd">
	<description>PHPCS configuration for the Flux One plugin.</description>

	<file>flux-one.php</file>
	<file>uninstall.php</file>
	<file>app</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/vendor-prefixed/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<rule ref="WordPress"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="flux-one-command-bar"/>
			</property>
		</properties>
	</rule>
</ruleset>
