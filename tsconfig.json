{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@flux-one/*": ["assets/js/src/*"]
    }
  },
  "include": ["assets/js/src/**/*.ts", "assets/js/src/**/*.tsx", "assets/js/src/**/*.d.ts"]
}

